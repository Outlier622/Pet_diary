{
    "title": "DogCat API - L3.5",
    "timezone": "browser",
    "refresh": "5s",
    "schemaVersion": 39,
    "panels": [
      { "type": "stat", "title": "QPS",
        "targets":[{"expr":"sum(rate(http_requests_total[1m]))"}] },
      { "type": "stat", "title": "5xx Rate (5m)",
        "targets":[{"expr":"sum(rate(http_requests_total{code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))"}] },
      { "type": "stat", "title": "p95 Latency (s)",
        "targets":[{"expr":"histogram_quantile(0.95, sum(rate(http_request_seconds_bucket[5m])) by (le))"}] },
      { "type": "graph", "title": "Latency p50/p95/p99",
        "targets":[
          {"expr":"histogram_quantile(0.50, sum(rate(http_request_seconds_bucket[5m])) by (le))"},
          {"expr":"histogram_quantile(0.95, sum(rate(http_request_seconds_bucket[5m])) by (le))"},
          {"expr":"histogram_quantile(0.99, sum(rate(http_request_seconds_bucket[5m])) by (le))"}] },
      { "type": "graph", "title": "HTTP Codes",
        "targets":[{"expr":"sum(rate(http_requests_total[1m])) by (code)"}] },
      { "type": "graph", "title": "CPU & RSS",
        "targets":[
          {"expr":"process_cpu_percent"},
          {"expr":"process_rss_bytes"}] },
      { "type": "stat", "title": "Model Ready",
        "targets":[{"expr":"model_loaded"}] }
    ]
  }
  